# Server
PORT=3000

# App URL (for links in emails)
# e.g. https://skch-ai.vercel.app or http://localhost:5173 for dev
APP_URL=https://your-app.vercel.app

# Optional: custom logo URL for password reset emails (default: sktch.ai Cloudinary logo)
# EMAIL_LOGO_URL=https://res.cloudinary.com/dvzm9b086/image/upload/v1772907058/logo1_pc7noa.png

# Database
DB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?appName=app

# Auth
JWT_SECRET=your-secret-key-min-32-chars

# SMTP (required for forgot password / OTP emails)
# Route: POST /api/auth/forgot-password

# Option A - Brevo (recommended):
#   Get credentials: Brevo → Settings → SMTP & API → SMTP
#   Use SMTP key as password (not API key)
#   SMTP_FROM must be a verified sender in Brevo
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-login-email
SMTP_PASS=your-smtp-key
SMTP_FROM=verified-sender@yourdomain.com

# Option B - Google Gmail:
#   1. Enable 2-Step Verification
#   2. Create App Password: Google Account → Security → App passwords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-16-char-app-password

# Optional: use SMTP_SECURE=true for port 465
# SMTP_SECURE=true
